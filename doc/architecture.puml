@startuml

!include theme.puml

skinparam nodesep 60
skinparam ranksep 90
skinparam rankdir TB

collections "Third Party APIs" as ThirdPartyAPIs

database Staging {
'  database "Resources" as StagingResources
'  database "Data" as StagingData {
    database "Raw" as StagingRaw
    database "Cleaned" as StagingCleaned
    database "Prepared" as StagingPrepared
    database "Served" as StagingServed
'  }
}

database "Versioned Raw Data" as VersionedRaw
database "Versioned Feature Store" as VersionedFeature

database "Versioned Model Store" as VersionedModel

component "Model Trainer" as ModelTrainer

component "Data Extractor" as DataExtractor
component "Data Transformer" as DataTransformer
component "Data Versioner" as DataVersioner
database "Project Instance Repo" as ProjectInstanceRepo #transparent

component "PV Prospect App" as PvProspectApp


'DataExtractor -[hidden]> DataTransformer

'StagingResources -[hidden]> StagingRaw
StagingCleaned -[hidden]> StagingPrepared
StagingRaw -[hidden]> StagingCleaned
StagingPrepared -[hidden]> StagingServed


'PvProspectApp --> StagingResources : A0: get
PvProspectApp --> VersionedModel : A1: get
PvProspectApp --> StagingServed : A2: get


'DataExtractor ---> StagingResources : E0: get
ThirdPartyAPIs <- DataExtractor : E1: call
DataExtractor --> StagingRaw : E2: put

'DataTransformer --> StagingResources : C1: get
DataTransformer --> StagingRaw : C1: get
DataTransformer --> StagingCleaned : C2: put\nP1: get

DataTransformer <- DataTransformer : P2: calculate_POA
DataTransformer --> StagingPrepared : P3: put
DataTransformer --> StagingServed : P4: put

StagingRaw <-- DataVersioner : V1: get
VersionedRaw <- DataVersioner : V2: push (dvc)

StagingPrepared <-- DataVersioner : V3: get
VersionedFeature <-- DataVersioner : V4: push (dvc)
DataVersioner -> ProjectInstanceRepo : V5: tag data-v<date>

VersionedFeature <-- ModelTrainer : M1: pull (dvc)
VersionedModel <-- ModelTrainer : M2: push (dvc)
ProjectInstanceRepo <- ModelTrainer : M3: tag model-v<date>

@enduml
