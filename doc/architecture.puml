@startuml

!include theme.puml

collections "Third Party APIs" as ThirdPartyAPIs

database "Staging" as Staging {
  database "Raw" as StagingRaw
  database "Cleaned" as StagingCleaned
  database "Prepared" as StagingPrepared
}

database "Versioned Raw Data" as VersionedRawData
database "Versioned Project Data" as VersionedProjectData
database "Versioned Model Data" as VersionedModelData

VersionedRawData -[hidden]> VersionedModelData

component "Data Extractor" as DataExtractor
component "Data Transformer" as DataTransformer

component Models {
  component "Weather Model" as WeatherModel
  component "PV Model" as PvModel
}

component "Model Trainer" as ModelTrainer

component "PV Prospect App" as PvProspectApp {
  component "Prediction API" as PredictionApi
  component "Validation API" as ValidationApi
  component "Irradiance Calculator" as IrradianceCalculator
  component "In-Memory Data" as InMemoryData
}

component "Data Versioner" as DataVersioner
database "Version Control Repo" as VCRepo

actor User

User --> ValidationApi
User --> PredictionApi : lat, lon, period

PredictionApi ---> WeatherModel : DNI, DHI, \ntemperature = \ncall_model(\nlat, lon, \nday, year)
PredictionApi -> IrradianceCalculator : calculate_POA(DNI, DHI)
PredictionApi ----> PvModel : predicted\nenergy \nyield = \ncall_model(\nPOA, \ntemperature)

ValidationApi --> PvModel : predicted\nenergy\nyield = \ncall_model(\nPOA, \ntemperature, \nsite ID)
ValidationApi --> InMemoryData : get_actual_energy_yield()

VersionedModelData <-- ModelTrainer : M1: pulls
Models <-- ModelTrainer : M2: trains

ThirdPartyAPIs <--- DataExtractor : E2: calls

VersionedProjectData <-- DataExtractor: E1: pulls
DataExtractor --> StagingRaw : E3: puts

VersionedProjectData <-[hidden]- DataTransformer
DataTransformer --> StagingRaw : C1: gets
DataTransformer --> StagingCleaned : C2: puts\nP1: gets
DataTransformer --> StagingPrepared : P2: puts
StagingCleaned -[hidden]> StagingPrepared

InMemoryData <--- DataTransformer : P3: puts

StagingRaw <-- DataVersioner : V1: gets
DataVersioner -> VersionedRawData : V2: pushes (using DVC)

StagingPrepared <-- DataVersioner : V3: gets
VersionedModelData <-- DataVersioner : V4: pushes (using DVC)
DataVersioner -> VCRepo : V5: pushes (using Git)

InMemoryData ---> VersionedModelData : A1: pulls
InMemoryData ---> StagingPrepared : A2: gets

@enduml
