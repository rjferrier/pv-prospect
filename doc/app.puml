@startuml

!include theme.puml

component "PV Prospect App" as PvProspectApp {
  component "Prediction API" as PredictionApi
  component "Weather Model" as WeatherModel
  component "PV Model" as PvModel
  component "Validation API" as ValidationApi
}

actor User

User --> PredictionApi : predict \n(location, \nperiod)

PredictionApi --> WeatherModel : DNI, DHI, \ntemperature = \ncall_model(\nlat, lon, \nday, year)
PredictionApi <- PredictionApi : calculate_POA
PredictionApi --> PvModel : predicted\nenergy \nyield = \ncall_model(\nPOA, \ntemperature)

User --> ValidationApi : validate(site)
ValidationApi --> PvModel

@enduml
